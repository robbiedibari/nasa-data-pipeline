UNION
SELECT customer_id FROM orders_2024;

-- ✅ Best Practice: UNION ALL then DISTINCT
SELECT DISTINCT customer_id
FROM (
    SELECT customer_id FROM orders_2023
    UNION ALL
    SELECT customer_id FROM orders_2024
) t;
```

---
### AGGREGATING DATA

##### #17 Use BRIN (Columnstore-like) Indexes for Large Tables

```sql
-- ❌ Bad: Full table scan on time-series data
SELECT * FROM logs WHERE log_date >= '2024-01-01';

-- ✅ Best Practice: BRIN index (lightweight, block-based)
CREATE INDEX idx_logs_date_brin ON logs USING BRIN(log_date);
```

---

##### #18 Pre-Aggregate Data

```sql
-- ❌ Bad: Aggregate huge tables on every query
SELECT customer_id, SUM(amount)
FROM sales
GROUP BY customer_id;

-- ✅ Best Practice: Materialized View (pre-computed)
CREATE MATERIALIZED VIEW mv_sales_summary AS
SELECT customer_id, SUM(amount) total_amount
FROM sales
GROUP BY customer_id;

-- Refresh when needed
REFRESH MATERIALIZED VIEW mv_sales_summary;
```

---

### SUBQUERIES
##### #19 Use EXISTS Instead of IN for Large Lists

```sql
-- ❌ Bad: IN with many values
SELECT * FROM customers
WHERE id IN (SELECT customer_id FROM orders);

-- ✅ Best Practice: EXISTS
SELECT * FROM customers c
WHERE EXISTS (
    SELECT 1 FROM orders o WHERE o.customer_id = c.id
);
```

---

##### #20 Use CTEs to Simplify Queries

```sql
-- ❌ Bad: Repeated subqueries
SELECT c.id, c.name,
   (SELECT COUNT(*) FROM orders o WHERE o.customer_id = c.id) order_count
FROM customers c;

-- ✅ Best Practice: CTE
WITH order_counts AS (
    SELECT customer_id, COUNT(*) cnt
    FROM orders
    GROUP BY customer_id
)
SELECT c.id, c.name, oc.cnt
FROM customers c
LEFT JOIN order_counts oc ON c.id = oc.customer_id;
```

---
### DDL
##### #21 Choose Correct Data Types

```sql
-- ❌ Bad: Using TEXT for fixed length values
CREATE TABLE users (phone TEXT);

-- ✅ Best Practice: Use VARCHAR(n) or NUMERIC
CREATE TABLE users (phone VARCHAR(15));

-- Avoid using Varchar(n) to but it is necessary most of the time

```

---

##### #22 Avoid Excessive Lengths

```sql
-- ❌ Bad
CREATE TABLE users (bio VARCHAR(10000));
-- OR MAX

-- ✅ Best Practice
CREATE TABLE users (bio VARCHAR(500));
```

---

##### #23 Use NOT NULL Constraints

```sql
-- ❌ Bad: Columns allow NULLs by default
CREATE TABLE orders (order_date DATE);

-- ✅ Best Practice: Use NOT NULL when possible
CREATE TABLE orders (order_date DATE NOT NULL);
```

---

##### #24 Always Have a Primary Key

```sql
-- ❌ Bad: No primary key
CREATE TABLE logs (message TEXT, created_at TIMESTAMP);

-- ✅ Best Practice
CREATE TABLE logs (
    id BIGSERIAL PRIMARY KEY,
    message TEXT,
    created_at TIMESTAMP NOT NULL
);
```

---

##### #25 Index Foreign Keys

```sql
-- ❌ Bad: Foreign key without index (slow joins)
ALTER TABLE orders
ADD CONSTRAINT fk_orders_customers FOREIGN KEY (customer_id) REFERENCES customers(id);

-- ✅ Best Practice: Add index
CREATE INDEX idx_orders_customer_id ON orders(customer_id);
```

---
### INDEXING
##### #26 Avoid Over Indexing

```sql
-- ❌ Bad: Multiple indexes on same column
CREATE INDEX idx_orders_customer_id1 ON orders(customer_id);
CREATE INDEX idx_orders_customer_id2 ON orders(customer_id);

-- ✅ Best Practice: Keep only what’s needed
DROP INDEX idx_orders_customer_id2;
```

---

##### #27 Drop Unused Indexes

```sql
-- Find unused indexes
SELECT relname, idx_scan
FROM pg_stat_user_indexes
JOIN pg_index USING (indexrelid)
WHERE idx_scan = 0;  -- never used

-- Drop unused ones
DROP INDEX idx_unused;
```

---

##### #28 Keep Statistics Updated Weekly

```sql
-- Update statistics for optimizer
ANALYZE sales;
```

---

##### #29 Rebuild/Reorganize Indexes Weekly

```sql
-- Reorganize (lightweight)
REINDEX TABLE customers;

-- Or specific index
REINDEX INDEX idx_customers_name;
```

---

##### #30 Partition Large Tables

```sql
-- ❌ Bad: Huge single-table scans
SELECT * FROM sales WHERE sale_date >= '2024-01-01';

-- ✅ Best Practice: Partitioning
CREATE TABLE sales (
    id BIGSERIAL,
    sale_date DATE NOT NULL,
    amount NUMERIC
) PARTITION BY RANGE (sale_date);

CREATE TABLE sales_2024 PARTITION OF sales
FOR VALUES FROM ('2024-01-01') TO ('2025-01-01');
```

---

✅ **Key Takeaway**: Always balance **indexing** and **query rewrites** with **storage and write costs**. Use `EXPLAIN ANALYZE` in PostgreSQL to confirm improvements.

