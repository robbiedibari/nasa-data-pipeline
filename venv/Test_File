-- SELECT DATEDIFF(day, start_date, end_date) FROM projects;

-- PostgreSQL equivalent
SELECT end_date - start_date AS days_difference FROM projects;
SELECT current_date - birth_date AS age_in_days FROM employees;

-- For different units, use EXTRACT
