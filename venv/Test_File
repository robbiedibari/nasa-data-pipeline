```SQL
CREATE OR REPLACE PROCEDURE public.truncate_and_load()
LANGUAGE plpgsql
AS $$
BEGIN
	-- Step 1: Truncate the table to remove all existing data.
	-- TRUNCATE is faster than DELETE and reclaims disk space immediately.
	TRUNCATE TABLE bronze.crm_cust_info;
	 -- Step 2: Load the data from the CSV file into the table.
	 -- The list of columns () ensures data is loaded into the correct columns.
	COPY bronze.crm_cust_info(cst_id, cst_key, cst_firstname, cst_lastname, cst_martial_status, cst_gndr, cst_create_date)
	FROM '/usr/share/csv_import/cust_info.csv'
	DELIMITER ','
	-- The `HEADER` option indicates that the first row of the file is a header and should be skipped.
